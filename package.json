{
  "name": "dijkstra-cards",
  "version": "0.2.3",
  "description": "A carts shopping cart optimizer.",
  "type": "module",
  "scripts": {
    "generate-icons": "node scripts/generate-icons.mjs",
    "dev": "vite build --watch",
    "dev:page": "cross-env DEV_PAGE=1 vite",
    "dev:firefox": "cross-env TARGET_BROWSER=firefox vite build --watch",
    "build": "vite build",
    "build:firefox": "cross-env TARGET_BROWSER=firefox vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "check-all": "pnpm lint && pnpm type-check && pnpm format:check && pnpm build"
  },
  "dependencies": {
    "@primevue/themes": "^4.2.5",
    "@sentry/vue": "^10.42.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "sass": "^1.97.3",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.296",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.11",
    "vite-plugin-web-extension": "^4.1.1",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.2.0"
  }
}
