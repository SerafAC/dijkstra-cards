{
  "name": "dijkstra-cards",
  "version": "0.1.0",
  "description": "Vue 3 browser extension boilerplate with PrimeVue (Chrome & Firefox)",
  "type": "module",
  "scripts": {
    "generate-icons": "node scripts/generate-icons.mjs",
    "dev": "vite build --watch",
    "dev:firefox": "cross-env TARGET_BROWSER=firefox vite build --watch",
    "build": "vite build",
    "build:firefox": "cross-env TARGET_BROWSER=firefox vite build",
    "type-check": "vue-tsc --noEmit",
    "postinstall": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@primevue/themes": "^4.2.5",
    "primevue": "^4.2.5",
    "primeicons": "^7.0.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.296",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-web-extension": "^4.1.1",
    "vue-tsc": "^2.2.0"
  }
}
