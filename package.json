    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.296",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-web-extension": "^4.1.1",
    "vue-tsc": "^2.2.0"
  }
