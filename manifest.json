{
  "manifest_version": 3,
  "name": "Dijkstra Cards",
  "version": "0.2.3",
  "description": "A cards shopping cart optimizer.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Dijkstra Cards"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "scripts": [
      "src/background/index.ts"
    ],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "dijkstra-cards@example.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "windows",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.cardmarket.com/*"
  ]
}
